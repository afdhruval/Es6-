<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Just do it. — Todo List</title>
    <style>
        /* boiler plate */
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            width:100%;
            padding:30px;
            display:flex;
            flex-direction:column;
            justify-content:center;
            align-items:center;
            background:linear-gradient(
                90deg,
                #4d4d4d,
                #032b3a
            );
            color:white;
        }
        /* themes styles */
        body.theme1{
            background:linear-gradient(
                90deg,
                #4d4d4d,
                #032b3a
            );
            color:white;
        }

        body.theme1 .task{
            background:#1d2a36;
        }

        body.theme1 .form input{
            background:#111;
            color:white;
        }

        body.theme1 .form button{
            background:#ffe9e9;
        }

        body.theme2{
            background:linear-gradient(
                90deg,
                #41295a,
                #2f0743
            );
            color:white;
        }

        body.theme2 .task{
            background:#2d1e3f;
        }

        body.theme2 .form input{
            background:#170b24;
            color:white;
        }

        body.theme2 .form button{
            background:#f3d1ff;
            color:#222;
        }

        body.theme3{
            background:linear-gradient(
                90deg,
                #134e5e,
                #71b280
            );
            color:white;
        }

        body.theme3 .task{
            background:#1f3f46;
        }

        body.theme3 .form input{
            background:#10272c;
            color:white;
        }

        body.theme3 .form button{
            background:#dfffe2;
            color:#222;
        }

        .container{
            width:100%;
            display:flex;
            flex-direction:column;
            align-items:center;
        }
        .title{
            font-size:90px;
            font-weight:300;
            margin-bottom:40px;
            color:#f8eaea;
        }

        /* form styling  */
        .form{
            display:flex;
            align-items:center;
            margin-bottom:20px;
        }
        .form input{
            width:420px;
            padding:14px 18px;
            border:none;
            outline:none;
            background:#111;
            color:white;
            border-radius:30px 0 0 30px;
            font-size:16px;
        }
        .form button{
            padding:14px 22px;
            border:none;
            background:#ffe9e9;
            color:#222;
            border-radius:0 30px 30px 0;
            cursor:pointer;
            font-weight:bold;
            transition:0.3s;
        }
        .form button:hover{
            transform:scale(1.05);
        }
        /* tasks styling */
        .task{
            width:320px;
            background:#1d2a36;
            padding:12px 18px;
            border-radius:30px;
            display:flex;
            justify-content:space-between;
            align-items:center;
            margin-bottom:15px;
        }
        .task h2{
            font-size:18px;
            font-weight:300;
        }

        .done{
            text-decoration:line-through;
            opacity:0.6;
        }

        .actions{
            display:flex;
            gap:10px;
        }

        .actions button{
            width:35px;
            height:35px;
            border:none;
            border-radius:50%;
            cursor:pointer;
            font-size:16px;
            transition:0.3s;
        }

        .actions button:hover{
            transform:scale(1.1);
        }

        .complete{
            background:white;
            color:black;
        }

        .delete{
            background:#d9d9d9;
            color:black;
        }
        /* changing theme icon  */
        .theme{
            position:absolute;
            top:20px;
            right:20px;
            display:flex;
            gap:10px;
        }

        .circle{
            width:25px;
            height:25px;
            border-radius:50%;
            border:2px solid white;
            cursor:pointer;
        }

        .gray{
            background:#555;
        }

        .purple{
            background:#5b2a86;
        }

        .green{
            background:#2e8b57;
        }
    </style>
</head>
<body class="theme1">
    <div class="container">
        <h1 class="title">
            Just do it.
        </h1>
        <!-- new task form  -->
        <form action="/add" method="post" class="form">
            <input 
                type="text" 
                name="newTask"
                id="newTask"
                placeholder="Add a task..."
                required
            >
            <button type="submit">
                I Got This!
            </button>
        </form>
        <!-- list of the tasks -->
        <% tasks.forEach(task=>{ %>
            <div class="task">
                <h2 class="<%= task.done ? 'done' : '' %>">
                    <%= task.text %>
                </h2>
                <!-- actions buttons -->
                <div class="actions">
                    <a href="/done/<%=task.id%>">
                        <button class="complete">
                            ✓
                        </button>
                    </a>
                    <a href="/delete/<%=task.id%>">
                        <button class="delete">
                            ✕
                        </button>
                    </a>
                </div>
            </div>
        <% }) %>
    </div>
    <!-- theme buttons -->
    <div class="theme">
        <div 
            class="circle gray"
            onclick="changeTheme('theme1')"
        ></div>
        <div 
            class="circle purple"
            onclick="changeTheme('theme2')"
        ></div>
        <div 
            class="circle green"
            onclick="changeTheme('theme3')"
        ></div>
    </div>
    <script>
        // used for storing the theme and use in the page
        let savedTheme = localStorage.getItem("Theme")
        if(savedTheme){
            document.body.className = savedTheme
        }

        // changing the theme and setting in the localstorage
        function changeTheme(theme){
            localStorage.setItem("Theme", theme)
            document.body.className = theme
        }
    </script>
</body>
</html>